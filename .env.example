# Copy to `.env` and fill in. `.env` is gitignored.

# OpenAI key — Cognee uses this for Topic/Hook extraction + embeddings.
# Cognee reads LLM_API_KEY (and EMBEDDING_API_KEY if you split them).
LLM_API_KEY=

# YouTube Data API v3 key (Google Cloud Console → enable "YouTube Data API v3" → create API key).
YOUTUBE_API_KEY=

# Demo creator channel (handle). Competitors + trend keywords live in config.py.
CREATOR_HANDLE=@LanaBlakely

# Telegram bot: message @BotFather -> /newbot -> paste the token below.
# Then message your new bot once (anything) and hit GET /telegram/poll —
# it'll show you the chat_id to paste in as TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
